<div class="plugin-cleaner-admin">
  <h2>Plugin Cleaner</h2>
  <p>Deep scan of your database for orphaned plugin data — custom fields, settings, themes, badges, API keys, webhooks, uploads, and more.</p>

  <div class="plugin-cleaner-actions">
    <DButton
      @action={{this.runScan}}
      @disabled={{this.isScanning}}
      @label={{if this.isScanning "plugin_cleaner.scanning" "plugin_cleaner.run_scan"}}
      @icon={{if this.isScanning "spinner" "search"}}
      class="btn-primary"
    />
  </div>

  {{#if this.errorMessage}}
    <div class="alert alert-error">{{this.errorMessage}}</div>
  {{/if}}

  {{#if this.scanResult}}
    <div class="plugin-cleaner-results">

      {{! ── Summary Bar ── }}
      <div class="plugin-cleaner-summary-bar">
        <span class="scan-timestamp">Scanned at {{this.scanResult.timestamp}}</span>
        <span class="total-issues {{if this.scanResult.summary.total_issues "has-issues"}}">
          {{this.scanResult.summary.total_issues}} total issues found
        </span>
      </div>

      {{! ── Summary Stats ── }}
      <div class="plugin-cleaner-summary">
        <div class="stat-box {{if this.scanResult.summary.orphaned_custom_fields "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.orphaned_custom_fields}}</span>
          <span class="stat-label">Orphaned Custom Fields</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.orphaned_plugin_settings "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.orphaned_plugin_settings}}</span>
          <span class="stat-label">Orphaned Settings</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.inactive_themes "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.inactive_themes}}</span>
          <span class="stat-label">Inactive Themes</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.disabled_badges "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.disabled_badges}}</span>
          <span class="stat-label">Disabled Badges</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.stale_api_keys "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.stale_api_keys}}</span>
          <span class="stat-label">Stale API Keys</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.failing_webhooks "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.failing_webhooks}}</span>
          <span class="stat-label">Failing Webhooks</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.empty_tag_groups "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.empty_tag_groups}}</span>
          <span class="stat-label">Empty Tag Groups</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.empty_user_fields "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.empty_user_fields}}</span>
          <span class="stat-label">Empty User Fields</span>
        </div>
        <div class="stat-box {{if this.scanResult.summary.orphaned_uploads "has-issues"}}">
          <span class="stat-number">{{this.scanResult.summary.orphaned_uploads}}</span>
          <span class="stat-label">Orphaned Uploads</span>
        </div>
      </div>

      {{! ── Recommendations ── }}
      {{#if this.scanResult.recommendations.length}}
        <div class="plugin-cleaner-section">
          <h3>Recommendations</h3>
          <table class="d-table">
            <thead>
              <tr>
                <th>Severity</th>
                <th>Type</th>
                <th>Issue</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.scanResult.recommendations as |rec|}}
                <tr class="severity-{{rec.severity}}">
                  <td><span class="badge-severity badge-{{rec.severity}}">{{rec.severity}}</span></td>
                  <td><code>{{rec.type}}</code></td>
                  <td>{{rec.message}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <div class="alert alert-success">No issues detected — your database looks clean!</div>
      {{/if}}

      {{! ── Custom Fields Detail ── }}
      {{#if this.scanResult.details.custom_fields.user.length}}
        <div class="plugin-cleaner-section">
          <h3>User Custom Fields</h3>
          <table class="d-table">
            <thead><tr><th>Field</th><th>Records</th><th>Risk</th></tr></thead>
            <tbody>
              {{#each this.scanResult.details.custom_fields.user as |f|}}
                <tr class="{{if f.orphan "orphan-row"}}">
                  <td><code>{{f.field}}</code></td>
                  <td>{{f.count}}</td>
                  <td><span class="badge-severity badge-{{f.risk}}">{{f.risk}}</span></td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{/if}}

      {{! ── API Keys ── }}
      {{#if this.scanResult.details.api_keys.length}}
        <div class="plugin-cleaner-section">
          <h3>API Keys</h3>
          <table class="d-table">
            <thead><tr><th>Description</th><th>User</th><th>Last Used</th><th>Status</th></tr></thead>
            <tbody>
              {{#each this.scanResult.details.api_keys as |k|}}
                <tr class="{{if k.stale "orphan-row"}}">
                  <td>{{k.description}}</td>
                  <td>{{k.user}}</td>
                  <td>{{if k.last_used k.last_used "Never"}}</td>
                  <td>{{if k.stale "⚠️ Stale" "✅ Active"}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{/if}}

      {{! ── Webhooks ── }}
      {{#if this.scanResult.details.web_hooks.length}}
        <div class="plugin-cleaner-section">
          <h3>Webhooks</h3>
          <table class="d-table">
            <thead><tr><th>URL</th><th>Active</th><th>Last Status</th><th>Last Triggered</th></tr></thead>
            <tbody>
              {{#each this.scanResult.details.web_hooks as |w|}}
                <tr class="{{if w.failing "orphan-row"}}">
                  <td><code>{{w.payload_url}}</code></td>
                  <td>{{if w.active "✅" "❌"}}</td>
                  <td>{{if w.last_status w.last_status "—"}}</td>
                  <td>{{if w.last_triggered w.last_triggered "Never"}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{/if}}

      {{! ── Uploads ── }}
      {{#if this.scanResult.details.uploads.total}}
        <div class="plugin-cleaner-section">
          <h3>Uploads</h3>
          <div class="plugin-cleaner-summary">
            <div class="stat-box">
              <span class="stat-number">{{this.scanResult.details.uploads.total}}</span>
              <span class="stat-label">Total Uploads</span>
            </div>
            <div class="stat-box {{if this.scanResult.details.uploads.orphaned "has-issues"}}">
              <span class="stat-number">{{this.scanResult.details.uploads.orphaned}}</span>
              <span class="stat-label">Orphaned ({{this.scanResult.details.uploads.orphaned_pct}}%)</span>
            </div>
          </div>
        </div>
      {{/if}}

    </div>
  {{/if}}
</div>

